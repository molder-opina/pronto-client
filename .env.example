# Pronto Client Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED (Production)
# =============================================================================

# Flask secret key for session signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# API endpoint for pronto-api (backend)
PRONTO_API_BASE_URL=http://localhost:6082

# Internal API URL (for container-to-container communication)
# Optional: defaults to PRONTO_API_BASE_URL
# PRONTO_API_INTERNAL_BASE_URL=http://pronto-api:6082

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Kiosk secret for authenticating kiosk bootstrap requests
# Required in production for kiosk functionality
PRONTO_KIOSK_SECRET=

# Kiosk password for auto-created kiosk accounts
# If not set, a random password is generated (not suitable for production)
PRONTO_KIOSK_PASSWORD=

# Routes-only mode secret (for unit tests)
# Optional: if not set, a random secret is generated
# PRONTO_ROUTES_SECRET=

# =============================================================================
# CORS
# =============================================================================

# Allowed CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://client.pronto.local,https://admin.pronto.local

# Public origin of this client (for CORS in debug mode)
# PRONTO_CLIENT_PUBLIC_ORIGIN=http://localhost:9088

# =============================================================================
# OPTIONAL
# =============================================================================

# Enable email sending
SEND_EMAIL_ENABLED=true

# Number of proxies (for ProxyFix middleware)
# NUM_PROXIES=1

# Employee API base URL (for feedback links)
# EMPLOYEE_API_BASE_URL=http://localhost:9089

# System version (defaults to 1.0000)
# PRONTO_SYSTEM_VERSION=1.0000
